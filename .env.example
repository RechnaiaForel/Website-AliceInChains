# Скопируйте этот файл в .env и заполните своими значениями для локальной разработки.
# .env НЕ должен попадать в git (см. .gitignore).

# Сгенерировать новый: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-locally

# True локально, False в проде (Railway)
DEBUG=True

# Через запятую, без пробелов
ALLOWED_HOSTS=127.0.0.1,localhost

# Если не задано — локально используется sqlite3 автоматически.
# На Railway эту переменную создаёт сервис PostgreSQL сам.
# DATABASE_URL=postgres://user:password@host:port/dbname

CORS_ALLOWED_ORIGINS=https://*.up.railway.app
CSRF_TRUSTED_ORIGINS=https://*.up.railway.app
